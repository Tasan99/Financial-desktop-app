{
  "name": "financial-data-engine",
  "version": "1.0.0",
  "description": "Financial Data Engine Dashboard",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.emirtasan.financialengine",
    "productName": "Financial Data Engine",
    "win": {
      "target": "nsis"
    },
    "extraResources": [
      {
        "from": "dist/app.exe",
        "to": "app.exe"
      }
    ]
  },
  "author": "Emir Tasan",
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1"
  }
}